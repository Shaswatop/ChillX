# ChillX API Keys — Copy this to .env and fill in your keys
# Get your own free keys at:
#   Groq (free):     https://console.groq.com/keys
#   Gemini (free):   https://aistudio.google.com/apikey
#   OpenRouter:      https://openrouter.ai/keys
#
# At least GROQ_KEY is required for the AI chat to work.
# Or set your keys in the app at Settings > API Keys.

GROQ_KEY=your-groq-api-key
GROQ_KEY2=your-groq-api-key-2
GEMINI_KEY=your-gemini-api-key
GEMINI_KEY2=your-gemini-api-key-2
OPENROUTER_KEY=your-openrouter-api-key
OPENROUTER_KEY2=your-openrouter-api-key-2
DJANGO_SECRET_KEY=generate-a-random-secret-key
